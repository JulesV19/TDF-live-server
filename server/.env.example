# Copie ce fichier en  .env  (à la racine du projet, à côté de run.sh) et remplis-le.
# run.sh le charge automatiquement s'il existe. Le .env n'est pas versionné.

# Publication vers le Worker Cloudflare (accès hors réseau local).
# Laisse vide pour désactiver (mode LAN/Tailscale d'origine).
TDF_PUBLISH_URL="https://tdf-live.<ton-sous-domaine>.workers.dev/race/current"
TDF_PUBLISH_TOKEN="<le même token que celui passé à: wrangler secret put PUBLISH_TOKEN>"
